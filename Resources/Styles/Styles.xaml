<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- 🌈 Global Gradients -->
    <LinearGradientBrush x:Key="AppGradientLight" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{StaticResource WhiteSmokeAlt}" Offset="0.0" />
        <GradientStop Color="{StaticResource Gainsboro}" Offset="1.0" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="AppGradientDark" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{StaticResource DarkSlateGray}" Offset="0.0" />
        <GradientStop Color="{StaticResource DarkSlateGrayAlt}" Offset="1.0" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="AccentGradient" StartPoint="0,1" EndPoint="1,0">
        <GradientStop Color="{StaticResource DodgerBlue}" Offset="0.0" />
        <GradientStop Color="{StaticResource RoyalBlue}" Offset="1.0" />
    </LinearGradientBrush>

    <!-- 💎 Backgrounds -->
    <Style TargetType="Page" ApplyToDerivedTypes="True">
        <Setter Property="Padding" Value="16"/>
        <Setter Property="Background">
            <Setter.Value>
                <AppThemeBinding 
                    Light="{StaticResource AppGradientLight}"
                    Dark="{StaticResource AppGradientDark}" />
            </Setter.Value>
        </Setter>
    </Style>

    <!-- 🧭 Navigation / Shell -->
    <Style TargetType="Shell" ApplyToDerivedTypes="True">
        <Setter Property="Shell.BackgroundColor"
                Value="{AppThemeBinding Light={StaticResource SurfaceLight}, Dark={StaticResource SurfaceDark}}" />
        <Setter Property="Shell.ForegroundColor"
                Value="{AppThemeBinding Light={StaticResource DarkSlateGray}, Dark={StaticResource WhiteSmokeAlt}}" />
        <Setter Property="Shell.TitleColor"
                Value="{AppThemeBinding Light={StaticResource RoyalBlue}, Dark={StaticResource Lavender}}" />
    </Style>

    <!-- 🪩 Card Style -->
    <Style x:Key="CardStyle" TargetType="Frame">
        <Setter Property="CornerRadius" Value="24" />
        <Setter Property="Padding" Value="20" />
        <Setter Property="HasShadow" Value="True" />
        <Setter Property="Background">
            <Setter.Value>
                <AppThemeBinding 
                    Light="{StaticResource AppGradientLight}"
                    Dark="{StaticResource AppGradientDark}" />
            </Setter.Value>
        </Setter>
        <Setter Property="Shadow">
            <Setter.Value>
                <Shadow Brush="{AppThemeBinding Light={StaticResource ShadowLight}, Dark={StaticResource ShadowDark}}"
                        Offset="8,8"
                        Radius="18"
                        Opacity="0.25" />
            </Setter.Value>
        </Setter>
    </Style>

    <!-- 🔘 Primary Button -->
    <Style TargetType="Button" x:Key="PrimaryButton">
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="TextColor"
                Value="{AppThemeBinding Light={StaticResource WhiteSmokeAlt}, Dark={StaticResource WhiteSmoke}}" />
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,1" EndPoint="1,0">
                    <GradientStop Color="{StaticResource DodgerBlue}" Offset="0.0" />
                    <GradientStop Color="{StaticResource RoyalBlue}" Offset="1.0" />
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
        <Setter Property="Shadow">
            <Setter.Value>
                <Shadow Brush="{AppThemeBinding Light={StaticResource ShadowLight}, Dark={StaticResource ShadowDark}}"
                        Offset="5,5" Radius="10" Opacity="0.35"/>
            </Setter.Value>
        </Setter>
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal" />
                    <VisualState x:Name="Pressed">
                        <VisualState.Setters>
                            <Setter Property="Scale" Value="0.97" />
                            <Setter Property="Shadow.Opacity" Value="0.15" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <!-- 🧾 Label -->
    <Style TargetType="Label">
        <Setter Property="TextColor"
                Value="{AppThemeBinding Light={StaticResource DarkSlateGray},
                                          Dark={StaticResource WhiteSmokeAlt}}" />
        <Setter Property="FontFamily" Value="OpenSansRegular"/>
    </Style>

    <!-- 🧱 Borders -->
    <Style TargetType="Border">
        <Setter Property="StrokeShape" Value="RoundRectangle 12"/>
        <Setter Property="Stroke" Value="Transparent"/>
        <Setter Property="StrokeThickness" Value="0"/>
        <Setter Property="Background"
                Value="{AppThemeBinding Light={StaticResource SurfaceLight}, Dark={StaticResource SurfaceDark}}" />
    </Style>

</ResourceDictionary>
