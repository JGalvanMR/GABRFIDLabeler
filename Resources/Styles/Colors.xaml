<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui" xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!--  ============================================  -->
    <!--  🎨 SYSTEM COLORS - Light & Dark Themes  -->
    <!--  ============================================  -->

    <!--  Primary Brand Colors  -->
    <Color x:Key="PrimaryBlue">#0066CC</Color>
    <Color x:Key="PrimaryBlueLight">#0071E3</Color>

    <!--  Semantic Colors - Success/Warning/Error  -->
    <Color x:Key="SuccessGreen">#34C759</Color>
    <Color x:Key="SuccessGreenDark">#30D158</Color>
    <Color x:Key="WarningOrange">#FF9500</Color>
    <Color x:Key="WarningOrangeDark">#FF9F0A</Color>
    <Color x:Key="ErrorRed">#FF3B30</Color>
    <Color x:Key="ErrorRedDark">#FF453A</Color>

    <!--  Light Theme Colors  -->
    <Color x:Key="LightBackground">#F5F5F7</Color>
    <Color x:Key="LightSurface">#FFFFFF</Color>
    <Color x:Key="LightSurfaceSecondary">#F8F9FB</Color>
    <Color x:Key="LightBorder">#E0E4EA</Color>
    <Color x:Key="LightBorderLight">#E8ECF0</Color>
    <Color x:Key="LightTextPrimary">#1A1A2E</Color>
    <Color x:Key="LightTextSecondary">#6B7280</Color>
    <Color x:Key="LightTextTertiary">#9CA3AF</Color>

    <!--  Dark Theme Colors  -->
    <Color x:Key="DarkBackground">#1D1D1F</Color>
    <Color x:Key="DarkSurface">#2D2D44</Color>
    <Color x:Key="DarkSurfaceSecondary">#252538</Color>
    <Color x:Key="DarkBorder">#3A3A50</Color>
    <Color x:Key="DarkBorderLight">#3D3D5C</Color>
    <Color x:Key="DarkTextPrimary">#FFFFFF</Color>
    <Color x:Key="DarkTextSecondary">#B0B0B0</Color>
    <Color x:Key="DarkTextTertiary">#7A7A90</Color>

    <!--  Neutral Colors  -->
    <Color x:Key="Gray100">#F3F4F6</Color>
    <Color x:Key="Gray200">#E5E7EB</Color>
    <Color x:Key="Gray300">#D1D5DB</Color>
    <Color x:Key="Gray400">#9CA3AF</Color>
    <Color x:Key="Gray500">#6B7280</Color>
    <Color x:Key="Gray600">#4B5563</Color>
    <Color x:Key="Gray700">#374151</Color>

    <!--  Shadow Colors  -->
    <Color x:Key="ShadowLight">#1A000000</Color>
    <Color x:Key="ShadowDark">#4D000000</Color>



</ResourceDictionary>
