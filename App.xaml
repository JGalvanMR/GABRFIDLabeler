<?xml version="1.0" encoding="UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:GABRFIDLabeler.Converters"
             xmlns:local="clr-namespace:GABRFIDLabeler"
             x:Class="GABRFIDLabeler.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <converters:StringToBooleanConverter x:Key="StringToBooleanConverter" />
            <converters:CommandToBooleanConverter x:Key="CommandToBooleanConverter" />
            <converters:RadioButtonValueToCheckedConverter x:Key="RadioConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
