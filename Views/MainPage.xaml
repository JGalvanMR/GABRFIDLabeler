<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="GABRFIDLabeler.Views.MainPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:converters="clr-namespace:GABRFIDLabeler.Converters"
    xmlns:viewmodels="clr-namespace:GABRFIDLabeler.ViewModels"
    Title="Impresión RFID"
    x:DataType="{x:Type viewmodels:PrinterViewModel}">

    <ContentPage.BackgroundColor>
        <AppThemeBinding Dark="#12121C" Light="#F0F2F5" />
    </ContentPage.BackgroundColor>

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:RadioButtonValueToCheckedConverter x:Key="RadioConverter" />

            <!--  Entry interno sin bordes  -->
            <Style x:Key="FlatEntry" TargetType="Entry">
                <Setter Property="FontSize" Value="15" />
                <Setter Property="BackgroundColor" Value="Transparent" />
                <Setter Property="Margin" Value="0" />
            </Style>

            <!--  Frame contenedor de Entry  -->
            <Style x:Key="EntryFrame" TargetType="Frame">
                <Setter Property="Padding" Value="16,14" />
                <Setter Property="CornerRadius" Value="14" />
                <Setter Property="HasShadow" Value="False" />
                <Setter Property="Margin" Value="0" />
            </Style>

            <!--  Botón principal elevado  -->
            <Style x:Key="ActionBtn" TargetType="Button">
                <Setter Property="HeightRequest" Value="50" />
                <Setter Property="FontSize" Value="15" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="CornerRadius" Value="14" />
                <Setter Property="Margin" Value="0" />
                <Setter Property="TextColor" Value="White" />
            </Style>

            <!--  Card base  -->
            <Style x:Key="Card" TargetType="Frame">
                <Setter Property="CornerRadius" Value="20" />
                <Setter Property="HasShadow" Value="True" />
                <Setter Property="Margin" Value="4,0" />
                <Setter Property="Padding" Value="22" />
            </Style>

            <!--  Stat card  -->
            <Style x:Key="StatCard" TargetType="Frame">
                <Setter Property="CornerRadius" Value="18" />
                <Setter Property="HasShadow" Value="True" />
                <Setter Property="Padding" Value="18,16" />
            </Style>

            <!--  Modo radio frame  -->
            <Style x:Key="ModeFrame" TargetType="Frame">
                <Setter Property="Padding" Value="2" />
                <Setter Property="CornerRadius" Value="14" />
                <Setter Property="HasShadow" Value="False" />
                <Setter Property="Margin" Value="0" />
            </Style>

            <!--  Label sección  -->
            <Style x:Key="SectionLabel" TargetType="Label">
                <Setter Property="FontSize" Value="16" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="VerticalOptions" Value="Center" />
            </Style>

            <!--  Label entrada  -->
            <Style x:Key="InputPlaceholder" TargetType="Label">
                <Setter Property="FontSize" Value="12" />
                <Setter Property="Margin" Value="2,0,0,4" />
            </Style>
        </ResourceDictionary>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Padding="18,16" Spacing="18">

            <!--  Título Principal  -->
            <VerticalStackLayout
                Margin="0,10,0,0"
                HorizontalOptions="Center"
                Spacing="6">
                <Label
                    FontAttributes="Bold"
                    FontSize="26"
                    HorizontalOptions="Center"
                    LineHeight="1.2"
                    Text="Impresión de Etiquetas RFID">
                    <Label.TextColor>
                        <AppThemeBinding Dark="#F1F5F9" Light="#0F172A" />
                    </Label.TextColor>
                </Label>
                <Label
                    CharacterSpacing="0.3"
                    FontSize="13"
                    HorizontalOptions="Center"
                    Opacity="0.55"
                    Text="Sistema de gestión y trazabilidad">
                    <Label.TextColor>
                        <AppThemeBinding Dark="#94A3B8" Light="#475569" />
                    </Label.TextColor>
                </Label>
            </VerticalStackLayout>

            <!--  Selector de modo  -->
            <Frame Style="{StaticResource Card}">
                <Frame.BackgroundColor>
                    <AppThemeBinding Dark="#1E1E30" Light="#FFFFFF" />
                </Frame.BackgroundColor>
                <Frame.Shadow>
                    <Shadow
                        Brush="#0F172A"
                        Opacity="0.06"
                        Radius="16"
                        Offset="0,4" />
                </Frame.Shadow>
                <VerticalStackLayout Spacing="14">
                    <Label
                        Margin="4,0,0,0"
                        CharacterSpacing="0.8"
                        FontAttributes="Bold"
                        FontSize="11"
                        Text="Modo de Operación">
                        <Label.TextColor>
                            <AppThemeBinding Dark="#64748B" Light="#94A3B8" />
                        </Label.TextColor>
                    </Label>
                    <Grid ColumnSpacing="8" HorizontalOptions="FillAndExpand">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Frame Grid.Column="0" Style="{StaticResource ModeFrame}">
                            <Frame.BackgroundColor>
                                <AppThemeBinding Dark="#2A2A42" Light="#EFF3FA" />
                            </Frame.BackgroundColor>
                            <Frame.BorderColor>
                                <AppThemeBinding Dark="#3D3D58" Light="#DDE4F0" />
                            </Frame.BorderColor>
                            <RadioButton
                                Margin="2"
                                Content="Parámetros"
                                FontSize="13"
                                GroupName="Modo"
                                HorizontalOptions="Center"
                                IsChecked="{Binding SelectedMode, Converter={StaticResource RadioConverter}, ConverterParameter=Parameters, Mode=Default}"
                                VerticalOptions="Center"
                                Value="Parameters">
                                <RadioButton.TextColor>
                                    <AppThemeBinding Dark="#CBD5E1" Light="#334155" />
                                </RadioButton.TextColor>
                            </RadioButton>
                        </Frame>
                        <Frame Grid.Column="1" Style="{StaticResource ModeFrame}">
                            <Frame.BackgroundColor>
                                <AppThemeBinding Dark="#2A2A42" Light="#EFF3FA" />
                            </Frame.BackgroundColor>
                            <Frame.BorderColor>
                                <AppThemeBinding Dark="#3D3D58" Light="#DDE4F0" />
                            </Frame.BorderColor>
                            <RadioButton
                                Margin="2"
                                Content="Reimpresión"
                                FontSize="13"
                                GroupName="Modo"
                                HorizontalOptions="Center"
                                IsChecked="{Binding SelectedMode, Converter={StaticResource RadioConverter}, ConverterParameter=Reimpresion, Mode=Default}"
                                VerticalOptions="Center">
                                <RadioButton.TextColor>
                                    <AppThemeBinding Dark="#CBD5E1" Light="#334155" />
                                </RadioButton.TextColor>
                            </RadioButton>
                        </Frame>
                        <Frame Grid.Column="2" Style="{StaticResource ModeFrame}">
                            <Frame.BackgroundColor>
                                <AppThemeBinding Dark="#2A2A42" Light="#EFF3FA" />
                            </Frame.BackgroundColor>
                            <Frame.BorderColor>
                                <AppThemeBinding Dark="#3D3D58" Light="#DDE4F0" />
                            </Frame.BorderColor>
                            <RadioButton
                                Margin="2"
                                Content="Nueva Etiqueta"
                                FontSize="13"
                                GroupName="Modo"
                                HorizontalOptions="Center"
                                IsChecked="{Binding SelectedMode, Converter={StaticResource RadioConverter}, ConverterParameter=NuevaEtiqueta, Mode=Default}"
                                VerticalOptions="Center">
                                <RadioButton.TextColor>
                                    <AppThemeBinding Dark="#CBD5E1" Light="#334155" />
                                </RadioButton.TextColor>
                            </RadioButton>
                        </Frame>
                    </Grid>
                </VerticalStackLayout>
            </Frame>

            <!--  Estadísticas  -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">

                <Frame Grid.Column="0" Style="{StaticResource StatCard}">
                    <Frame.BackgroundColor>
                        <AppThemeBinding Dark="#1E1E30" Light="#FFFFFF" />
                    </Frame.BackgroundColor>
                    <Frame.Shadow>
                        <Shadow
                            Brush="#2563EB"
                            Opacity="0.08"
                            Radius="14"
                            Offset="0,3" />
                    </Frame.Shadow>
                    <VerticalStackLayout HorizontalOptions="Center" Spacing="2">
                        <!--  Indicador decorativo  -->
                        <BoxView
                            CornerRadius="2"
                            HeightRequest="3"
                            HorizontalOptions="Center"
                            WidthRequest="32">
                            <BoxView.Color>
                                <AppThemeBinding Dark="#3B82F6" Light="#2563EB" />
                            </BoxView.Color>
                        </BoxView>
                        <Label
                            Margin="0,4,0,0"
                            FontAttributes="Bold"
                            FontSize="28"
                            HorizontalOptions="Center"
                            Text="{Binding TotalReimpresosTanda}"
                            TextColor="{AppThemeBinding Light=#2563EB,
                                                        Dark=#60A5FA}" />
                        <Label
                            Margin="0,0,0,0"
                            CharacterSpacing="0.5"
                            FontSize="11"
                            HorizontalOptions="Center"
                            Text="Impresas"
                            TextColor="{AppThemeBinding Light=#94A3B8,
                                                        Dark=#64748B}" />
                    </VerticalStackLayout>
                </Frame>

                <Frame Grid.Column="1" Style="{StaticResource StatCard}">
                    <Frame.BackgroundColor>
                        <AppThemeBinding Dark="#1E1E30" Light="#FFFFFF" />
                    </Frame.BackgroundColor>
                    <Frame.Shadow>
                        <Shadow
                            Brush="#059669"
                            Opacity="0.08"
                            Radius="14"
                            Offset="0,3" />
                    </Frame.Shadow>
                    <VerticalStackLayout HorizontalOptions="Center" Spacing="2">
                        <BoxView
                            CornerRadius="2"
                            HeightRequest="3"
                            HorizontalOptions="Center"
                            WidthRequest="32">
                            <BoxView.Color>
                                <AppThemeBinding Dark="#10B981" Light="#059669" />
                            </BoxView.Color>
                        </BoxView>
                        <Label
                            Margin="0,4,0,0"
                            FontAttributes="Bold"
                            FontSize="28"
                            HorizontalOptions="Center"
                            Text="{Binding LabelsToPrint}"
                            TextColor="{AppThemeBinding Light=#059669,
                                                        Dark=#34D399}" />
                        <Label
                            Margin="0,0,0,0"
                            CharacterSpacing="0.5"
                            FontSize="11"
                            HorizontalOptions="Center"
                            Text="En Lote"
                            TextColor="{AppThemeBinding Light=#94A3B8,
                                                        Dark=#64748B}" />
                    </VerticalStackLayout>
                </Frame>
            </Grid>

            <!--  Conexión  -->
            <Frame Style="{StaticResource Card}">
                <Frame.BackgroundColor>
                    <AppThemeBinding Dark="#1E1E30" Light="#FFFFFF" />
                </Frame.BackgroundColor>
                <Frame.Shadow>
                    <Shadow
                        Brush="#0F172A"
                        Opacity="0.06"
                        Radius="16"
                        Offset="0,4" />
                </Frame.Shadow>
                <VerticalStackLayout Spacing="14">
                    <HorizontalStackLayout Spacing="10">
                        <Frame
                            Padding="0"
                            CornerRadius="10"
                            HasShadow="False"
                            HeightRequest="34"
                            WidthRequest="34">
                            <Frame.BackgroundColor>
                                <AppThemeBinding Dark="#1E3A5F" Light="#EFF6FF" />
                            </Frame.BackgroundColor>
                            <Label
                                FontSize="16"
                                HorizontalOptions="Center"
                                Text="⚙"
                                VerticalOptions="Center" />
                        </Frame>
                        <Label Style="{StaticResource SectionLabel}" Text="Configuración de Impresora">
                            <Label.TextColor>
                                <AppThemeBinding Dark="#F1F5F9" Light="#0F172A" />
                            </Label.TextColor>
                        </Label>
                    </HorizontalStackLayout>

                    <Label Style="{StaticResource InputPlaceholder}" Text="Dirección IP">
                        <Label.TextColor>
                            <AppThemeBinding Dark="#64748B" Light="#94A3B8" />
                        </Label.TextColor>
                    </Label>
                    <Frame Style="{StaticResource EntryFrame}">
                        <Frame.BackgroundColor>
                            <AppThemeBinding Dark="#16162A" Light="#F8FAFC" />
                        </Frame.BackgroundColor>
                        <Frame.BorderColor>
                            <AppThemeBinding Dark="#2D2D48" Light="#E2E8F0" />
                        </Frame.BorderColor>
                        <Entry
                            Keyboard="Url"
                            Placeholder="192.168.1.100"
                            Style="{StaticResource FlatEntry}"
                            Text="{Binding PrinterIp}">
                            <Entry.PlaceholderColor>
                                <AppThemeBinding Dark="#475569" Light="#CBD5E1" />
                            </Entry.PlaceholderColor>
                            <Entry.TextColor>
                                <AppThemeBinding Dark="#F1F5F9" Light="#0F172A" />
                            </Entry.TextColor>
                        </Entry>
                    </Frame>

                    <Button
                        Command="{Binding ConnectCommand}"
                        Style="{StaticResource ActionBtn}"
                        Text="Conectar">
                        <Button.BackgroundColor>
                            <AppThemeBinding Dark="#3B82F6" Light="#2563EB" />
                        </Button.BackgroundColor>
                        <Button.Shadow>
                            <Shadow
                                Brush="#2563EB"
                                Opacity="0.25"
                                Radius="10"
                                Offset="0,4" />
                        </Button.Shadow>
                    </Button>
                </VerticalStackLayout>
            </Frame>

            <!--  Parámetros de impresión  -->
            <Frame IsVisible="{Binding IsImpresionVisible}" Style="{StaticResource Card}">
                <Frame.BackgroundColor>
                    <AppThemeBinding Dark="#1E1E30" Light="#FFFFFF" />
                </Frame.BackgroundColor>
                <Frame.Shadow>
                    <Shadow
                        Brush="#0F172A"
                        Opacity="0.06"
                        Radius="16"
                        Offset="0,4" />
                </Frame.Shadow>
                <VerticalStackLayout Spacing="14">
                    <HorizontalStackLayout Spacing="10">
                        <Frame
                            Padding="0"
                            CornerRadius="10"
                            HasShadow="False"
                            HeightRequest="34"
                            WidthRequest="34">
                            <Frame.BackgroundColor>
                                <AppThemeBinding Dark="#1E3A5F" Light="#EFF6FF" />
                            </Frame.BackgroundColor>
                            <Label
                                FontSize="16"
                                HorizontalOptions="Center"
                                Text="📋"
                                VerticalOptions="Center" />
                        </Frame>
                        <Label Style="{StaticResource SectionLabel}" Text="Parámetros de Impresión">
                            <Label.TextColor>
                                <AppThemeBinding Dark="#F1F5F9" Light="#0F172A" />
                            </Label.TextColor>
                        </Label>
                    </HorizontalStackLayout>

                    <!--  Fecha  -->
                    <Label Style="{StaticResource InputPlaceholder}" Text="Fecha de compra">
                        <Label.TextColor>
                            <AppThemeBinding Dark="#64748B" Light="#94A3B8" />
                        </Label.TextColor>
                    </Label>
                    <Frame Style="{StaticResource EntryFrame}">
                        <Frame.BackgroundColor>
                            <AppThemeBinding Dark="#16162A" Light="#F8FAFC" />
                        </Frame.BackgroundColor>
                        <Frame.BorderColor>
                            <AppThemeBinding Dark="#2D2D48" Light="#E2E8F0" />
                        </Frame.BorderColor>
                        <Entry
                            Placeholder="Ej. MAR-2025"
                            Style="{StaticResource FlatEntry}"
                            Text="{Binding Date}"
                            TextTransform="Uppercase">
                            <Entry.PlaceholderColor>
                                <AppThemeBinding Dark="#475569" Light="#CBD5E1" />
                            </Entry.PlaceholderColor>
                            <Entry.TextColor>
                                <AppThemeBinding Dark="#F1F5F9" Light="#0F172A" />
                            </Entry.TextColor>
                        </Entry>
                    </Frame>

                    <!--  Última etiqueta  -->
                    <Label Style="{StaticResource InputPlaceholder}" Text="Última etiqueta impresa">
                        <Label.TextColor>
                            <AppThemeBinding Dark="#64748B" Light="#94A3B8" />
                        </Label.TextColor>
                    </Label>
                    <Frame Style="{StaticResource EntryFrame}">
                        <Frame.BackgroundColor>
                            <AppThemeBinding Dark="#16162A" Light="#F8FAFC" />
                        </Frame.BackgroundColor>
                        <Frame.BorderColor>
                            <AppThemeBinding Dark="#2D2D48" Light="#E2E8F0" />
                        </Frame.BorderColor>
                        <Entry
                            Keyboard="Numeric"
                            Placeholder="Número de etiqueta"
                            Style="{StaticResource FlatEntry}"
                            Text="{Binding LabelPrint}">
                            <Entry.PlaceholderColor>
                                <AppThemeBinding Dark="#475569" Light="#CBD5E1" />
                            </Entry.PlaceholderColor>
                            <Entry.TextColor>
                                <AppThemeBinding Dark="#F1F5F9" Light="#0F172A" />
                            </Entry.TextColor>
                        </Entry>
                    </Frame>

                    <!--  Cantidad  -->
                    <Label Style="{StaticResource InputPlaceholder}" Text="Cantidad a imprimir">
                        <Label.TextColor>
                            <AppThemeBinding Dark="#64748B" Light="#94A3B8" />
                        </Label.TextColor>
                    </Label>
                    <Frame Style="{StaticResource EntryFrame}">
                        <Frame.BackgroundColor>
                            <AppThemeBinding Dark="#16162A" Light="#F8FAFC" />
                        </Frame.BackgroundColor>
                        <Frame.BorderColor>
                            <AppThemeBinding Dark="#2D2D48" Light="#E2E8F0" />
                        </Frame.BorderColor>
                        <Entry
                            Keyboard="Numeric"
                            Placeholder="Ej. 50"
                            Style="{StaticResource FlatEntry}"
                            Text="{Binding LabelsToPrint}">
                            <Entry.PlaceholderColor>
                                <AppThemeBinding Dark="#475569" Light="#CBD5E1" />
                            </Entry.PlaceholderColor>
                            <Entry.TextColor>
                                <AppThemeBinding Dark="#F1F5F9" Light="#0F172A" />
                            </Entry.TextColor>
                        </Entry>
                    </Frame>

                    <!--  Acciones  -->
                    <VerticalStackLayout Margin="0,6,0,0" Spacing="10">
                        <Button
                            Command="{Binding PrintBatchCommand}"
                            CornerRadius="14"
                            FontAttributes="Bold"
                            FontSize="16"
                            HeightRequest="52"
                            Style="{StaticResource PrimaryButton}"
                            Text="Imprimir lote de etiquetas">
                            <Button.BackgroundColor>
                                <AppThemeBinding Dark="#3B82F6" Light="#2563EB" />
                            </Button.BackgroundColor>
                            <Button.TextColor>
                                <AppThemeBinding Dark="#FFFFFF" Light="#FFFFFF" />
                            </Button.TextColor>
                            <Button.Shadow>
                                <Shadow
                                    Brush="#2563EB"
                                    Opacity="0.28"
                                    Radius="12"
                                    Offset="0,4" />
                            </Button.Shadow>
                        </Button>
                        <Button
                            Command="{Binding PrintSingleCommand}"
                            CornerRadius="12"
                            FontSize="14"
                            HeightRequest="44"
                            IsEnabled="False"
                            IsVisible="False"
                            Style="{StaticResource PrimaryButton}"
                            Text="Impresión simple" />
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Frame>

            <!--  Reimpresión de etiquetas  -->
            <Frame IsVisible="{Binding IsReimpresionVisible}" Style="{StaticResource Card}">
                <Frame.BackgroundColor>
                    <AppThemeBinding Dark="#1E1E30" Light="#FFFFFF" />
                </Frame.BackgroundColor>
                <Frame.Shadow>
                    <Shadow
                        Brush="#0F172A"
                        Opacity="0.06"
                        Radius="16"
                        Offset="0,4" />
                </Frame.Shadow>
                <VerticalStackLayout Spacing="14">
                    <HorizontalStackLayout Spacing="10">
                        <Frame
                            Padding="0"
                            CornerRadius="10"
                            HasShadow="False"
                            HeightRequest="34"
                            WidthRequest="34">
                            <Frame.BackgroundColor>
                                <AppThemeBinding Dark="#2E1065" Light="#F5F3FF" />
                            </Frame.BackgroundColor>
                            <Label
                                FontSize="16"
                                HorizontalOptions="Center"
                                Text="🔄"
                                VerticalOptions="Center" />
                        </Frame>
                        <Label Style="{StaticResource SectionLabel}" Text="Reimpresión de Etiquetas">
                            <Label.TextColor>
                                <AppThemeBinding Dark="#F1F5F9" Light="#0F172A" />
                            </Label.TextColor>
                        </Label>
                    </HorizontalStackLayout>

                    <Label Style="{StaticResource InputPlaceholder}" Text="EPC o número de etiqueta">
                        <Label.TextColor>
                            <AppThemeBinding Dark="#64748B" Light="#94A3B8" />
                        </Label.TextColor>
                    </Label>
                    <Frame Style="{StaticResource EntryFrame}">
                        <Frame.BackgroundColor>
                            <AppThemeBinding Dark="#16162A" Light="#F8FAFC" />
                        </Frame.BackgroundColor>
                        <Frame.BorderColor>
                            <AppThemeBinding Dark="#2D2D48" Light="#E2E8F0" />
                        </Frame.BorderColor>
                        <Entry
                            x:Name="EpcEntry"
                            Placeholder="Escanear o escribir..."
                            Style="{StaticResource FlatEntry}"
                            Text="{Binding EpcToReprint}">
                            <Entry.PlaceholderColor>
                                <AppThemeBinding Dark="#475569" Light="#CBD5E1" />
                            </Entry.PlaceholderColor>
                            <Entry.TextColor>
                                <AppThemeBinding Dark="#F1F5F9" Light="#0F172A" />
                            </Entry.TextColor>
                        </Entry>
                    </Frame>

                    <Button
                        Command="{Binding ReprintCommand}"
                        Style="{StaticResource ActionBtn}"
                        Text="Reimprimir Manual">
                        <Button.BackgroundColor>
                            <AppThemeBinding Dark="#8B5CF6" Light="#7C3AED" />
                        </Button.BackgroundColor>
                        <Button.TextColor>
                            <AppThemeBinding Dark="#FFFFFF" Light="#FFFFFF" />
                        </Button.TextColor>
                        <Button.Shadow>
                            <Shadow
                                Brush="#7C3AED"
                                Opacity="0.25"
                                Radius="10"
                                Offset="0,4" />
                        </Button.Shadow>
                    </Button>

                    <!--  Separador sutil  -->
                    <BoxView Margin="0,2" HeightRequest="1">
                        <BoxView.Color>
                            <AppThemeBinding Dark="#2A2A42" Light="#F1F5F9" />
                        </BoxView.Color>
                    </BoxView>

                    <VerticalStackLayout Spacing="10">
                        <Label
                            Margin="4,0,0,0"
                            CharacterSpacing="1"
                            FontAttributes="Bold"
                            FontSize="10"
                            Text="PROPUESTAS SIN MOVIMIENTOS">
                            <Label.TextColor>
                                <AppThemeBinding Dark="#475569" Light="#94A3B8" />
                            </Label.TextColor>
                        </Label>

                        <Frame
                            Padding="4"
                            BackgroundColor="Transparent"
                            BorderColor="{AppThemeBinding Light=#F1F5F9,
                                                          Dark=#2A2A42}"
                            CornerRadius="14"
                            HasShadow="False">
                            <CollectionView HeightRequest="250" ItemsSource="{Binding EtiquetasSugeridas}">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Padding="4,3">
                                            <Button
                                                Margin="0"
                                                BackgroundColor="{AppThemeBinding Light=#F8FAFC,
                                                                                  Dark=#1A1A30}"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:PrinterViewModel}}, Path=ReprintFromListCommand}"
                                                CommandParameter="{Binding .}"
                                                CornerRadius="12"
                                                FontSize="13"
                                                HeightRequest="42"
                                                Text="{Binding .}"
                                                TextColor="{AppThemeBinding Light=#334155,
                                                                            Dark=#CBD5E1}">
                                                <Button.BorderColor>
                                                    <AppThemeBinding Dark="#2D2D48" Light="#E2E8F0" />
                                                </Button.BorderColor>
                                                <Button.BorderWidth>
                                                    <AppThemeBinding Dark="1" Light="1" />
                                                </Button.BorderWidth>
                                            </Button>
                                        </Grid>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                                <CollectionView.EmptyView>
                                    <VerticalStackLayout
                                        Padding="20,40"
                                        HorizontalOptions="Center"
                                        Spacing="10"
                                        VerticalOptions="Center">
                                        <Frame
                                            Padding="0"
                                            CornerRadius="16"
                                            HasShadow="False"
                                            HeightRequest="56"
                                            HorizontalOptions="Center"
                                            WidthRequest="56">
                                            <Frame.BackgroundColor>
                                                <AppThemeBinding Dark="#1A1A30" Light="#F1F5F9" />
                                            </Frame.BackgroundColor>
                                            <Label
                                                FontSize="24"
                                                HorizontalOptions="Center"
                                                Text="📭"
                                                VerticalOptions="Center" />
                                        </Frame>
                                        <Label
                                            FontSize="13"
                                            HorizontalOptions="Center"
                                            HorizontalTextAlignment="Center"
                                            Text="Sin etiquetas pendientes">
                                            <Label.TextColor>
                                                <AppThemeBinding Dark="#64748B" Light="#94A3B8" />
                                            </Label.TextColor>
                                        </Label>
                                        <Label
                                            FontSize="11"
                                            HorizontalOptions="Center"
                                            HorizontalTextAlignment="Center"
                                            Opacity="0.7"
                                            Text="No se encontraron etiquetas sin primer movimiento">
                                            <Label.TextColor>
                                                <AppThemeBinding Dark="#475569" Light="#94A3B8" />
                                            </Label.TextColor>
                                        </Label>
                                    </VerticalStackLayout>
                                </CollectionView.EmptyView>
                            </CollectionView>
                        </Frame>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Frame>

            <!--  NUEVAS ETIQUETAS  -->
            <Frame IsVisible="{Binding IsNuevaEtiquetaVisible}" Style="{StaticResource Card}">
                <Frame.BackgroundColor>
                    <AppThemeBinding Dark="#1E1E30" Light="#FFFFFF" />
                </Frame.BackgroundColor>
                <Frame.Shadow>
                    <Shadow
                        Brush="#0F172A"
                        Opacity="0.06"
                        Radius="16"
                        Offset="0,4" />
                </Frame.Shadow>
                <VerticalStackLayout Spacing="14">
                    <HorizontalStackLayout Spacing="10">
                        <Frame
                            Padding="0"
                            CornerRadius="10"
                            HasShadow="False"
                            HeightRequest="34"
                            WidthRequest="34">
                            <Frame.BackgroundColor>
                                <AppThemeBinding Dark="#064E3B" Light="#ECFDF5" />
                            </Frame.BackgroundColor>
                            <Label
                                FontSize="16"
                                HorizontalOptions="Center"
                                Text="🏷"
                                VerticalOptions="Center" />
                        </Frame>
                        <Label Style="{StaticResource SectionLabel}" Text="Nuevas Etiquetas">
                            <Label.TextColor>
                                <AppThemeBinding Dark="#F1F5F9" Light="#0F172A" />
                            </Label.TextColor>
                        </Label>
                    </HorizontalStackLayout>

                    <Label Style="{StaticResource InputPlaceholder}" Text="EPC o número de etiqueta">
                        <Label.TextColor>
                            <AppThemeBinding Dark="#64748B" Light="#94A3B8" />
                        </Label.TextColor>
                    </Label>
                    <Frame Style="{StaticResource EntryFrame}">
                        <Frame.BackgroundColor>
                            <AppThemeBinding Dark="#16162A" Light="#F8FAFC" />
                        </Frame.BackgroundColor>
                        <Frame.BorderColor>
                            <AppThemeBinding Dark="#2D2D48" Light="#E2E8F0" />
                        </Frame.BorderColor>
                        <Entry
                            x:Name="EpcEntryNEW"
                            Placeholder="Escanear o escribir..."
                            ReturnCommand="{Binding ReprintNCommand}"
                            ReturnType="Send"
                            Style="{StaticResource FlatEntry}"
                            Text="{Binding EpcToReprintN}">
                            <Entry.PlaceholderColor>
                                <AppThemeBinding Dark="#475569" Light="#CBD5E1" />
                            </Entry.PlaceholderColor>
                            <Entry.TextColor>
                                <AppThemeBinding Dark="#F1F5F9" Light="#0F172A" />
                            </Entry.TextColor>
                        </Entry>
                    </Frame>

                    <Button
                        Command="{Binding ReprintNCommand}"
                        Style="{StaticResource ActionBtn}"
                        Text="Reimprimir etiqueta">
                        <Button.BackgroundColor>
                            <AppThemeBinding Dark="#10B981" Light="#059669" />
                        </Button.BackgroundColor>
                        <Button.TextColor>
                            <AppThemeBinding Dark="#FFFFFF" Light="#FFFFFF" />
                        </Button.TextColor>
                        <Button.Shadow>
                            <Shadow
                                Brush="#059669"
                                Opacity="0.25"
                                Radius="10"
                                Offset="0,4" />
                        </Button.Shadow>
                    </Button>
                </VerticalStackLayout>
            </Frame>

            <!--  Espacio inferior  -->
            <BoxView HeightRequest="12" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>